import pandas as pd

# Load the training dataset
train_df = pd.read_csv('/content/fraudTrain.csv')
print("Train Dataset Head:")
display(train_df.head())

# Load the testing dataset
test_df = pd.read_csv('/content/fraudTest.csv')
print("\nTest Dataset Head:")
display(test_df.head())

print("\nClass Imbalance in Train Dataset ('is_fraud' column):")
fraud_counts_train = train_df['is_fraud'].value_counts()
fraud_percentages_train = train_df['is_fraud'].value_counts(normalize=True) * 100
fraud_info_train = pd.DataFrame({'Count': fraud_counts_train, 'Percentage': fraud_percentages_train})
display(fraud_info_train)

print("\nClass Imbalance in Test Dataset ('is_fraud' column):")
fraud_counts_test = test_df['is_fraud'].value_counts()
fraud_percentages_test = test_df['is_fraud'].value_counts(normalize=True) * 100
fraud_info_test = pd.DataFrame({'Count': fraud_counts_test, 'Percentage': fraud_percentages_test})
display(fraud_info_test)

"""As expected, there is a significant class imbalance in both the training and testing datasets, with fraudulent transactions (`is_fraud=1`) representing a very small percentage of the total. This is a common characteristic of fraud detection problems and needs to be addressed during model training to prevent the model from simply predicting the majority class."""

