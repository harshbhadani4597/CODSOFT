import re
import nltk
from nltk.corpus import stopwords
from nltk.stem import PorterStemmer

nltk.download('stopwords')

stop_words = set(stopwords.words('english'))
stemmer = PorterStemmer()

def clean_text(text):
    text = text.lower() # Lowercase
    text = re.sub(r'[^a-z\s]', '', text) # Remove punctuation and numbers
    words = text.split() # Tokenize
    words = [stemmer.stem(word) for word in words if word not in stop_words] # Remove stopwords and stem
    return ' '.join(words)

# Apply cleaning to train_df
train_df['Cleaned_Description'] = train_df['Description'].apply(clean_text)
print("Cleaned_Description column added to train_df.")

# Apply cleaning to test_df
test_df['Cleaned_Description'] = test_df['Description'].apply(clean_text)
