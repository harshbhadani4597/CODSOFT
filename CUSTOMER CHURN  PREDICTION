import pandas as pd

df = pd.read_csv('/content/Churn_Modelling.csv')
display(df.head())

import matplotlib.pyplot as plt
import seaborn as sns

plt.figure(figsize=(8, 6))
sns.countplot(x='Gender', hue='Exited', data=df)
plt.title('Distribution of Customer Churn by Gender')
plt.xlabel('Gender')
plt.ylabel('Number of Customers')
plt.show()

# Drop irrelevant columns that are unique identifiers and not useful for prediction
df_processed = df.drop(['RowNumber', 'CustomerId', 'Surname'], axis=1)

# One-hot encode categorical features: 'Geography' and 'Gender'
df_processed = pd.get_dummies(df_processed, columns=['Geography', 'Gender'], drop_first=True)

display(df_processed.head())

# Separate features (X) and target variable (y)
X = df_processed.drop('Exited', axis=1)
y = df_processed['Exited']

print(f"Shape of X: {X.shape}")
print(f"Shape of y: {y.shape}")

